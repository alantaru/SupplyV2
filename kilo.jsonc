{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai-compatible/deepseek-v4-flash",
  "small_model": "openai-compatible/deepseek-v4-flash",
  "provider": {
    "openai-compatible": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "id": "deepseek-v4-flash",
          "tool_call": true,
          "reasoning": false,
          "temperature": true,
          "attachment": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "cost": {
            "input": 0.14,
            "output": 0.28
          },
          "options": {
            "temperature": 0.7,
            "top_p": 1.0
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "id": "deepseek-v4-pro",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "cost": {
            "input": 0.435,
            "output": 0.87
          },
          "options": {
            "temperature": 0.3,
            "top_p": 1.0
          }
        }
      }
    }
  },
  "permission": {
    "bash": "allow",
    "read": {
      "*": "allow"
    },
    "write": {
      "*.{py,js,ts,tsx,jsx,json,yaml,yml,toml,md,txt}": "allow"
    }
  },
  "auto_collapse_reasoning": false,
  "terminal_command_display": "expanded"
}
