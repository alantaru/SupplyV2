# URL base do sistema Supply 2026
E2E_BASE_URL=https://your-domain.com

# Credenciais por role (nunca commitar credenciais reais)
E2E_SUPERADMIN_USER=superadmin
E2E_SUPERADMIN_PASS=<senha_superadmin>

E2E_ADMIN_USER=admin_e2e
E2E_ADMIN_PASS=<senha_admin>

E2E_USER_USER=user_e2e
E2E_USER_PASS=<senha_user>

# Contrato de teste dedicado (isolado de produção)
E2E_TEST_CONTRACT_ID=e2e-test-contract-2026

# Timeout padrão em ms
E2E_DEFAULT_TIMEOUT=10000
